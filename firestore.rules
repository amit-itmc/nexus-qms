rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() { return hasRole('Admin'); }
    function isQA() { return hasRole('QA'); }
    function isManager() { return hasRole('Manager'); }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprints
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 256 &&
             data.role in ['Admin', 'QA', 'Manager', 'User'] &&
             data.keys().hasAll(['email', 'role', 'createdAt']) &&
             data.keys().size() <= 6;
    }

    function isValidDeviation(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.category in ['Minor', 'Major', 'Critical'] &&
             data.status in ['Draft', 'Open', 'Investigation', 'QA Review', 'Closed'] &&
             data.createdBy == request.auth.uid;
    }

    // 2.1 Deviations
    match /deviations/{deviationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidDeviation(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || isQA() || (existing().createdBy == request.auth.uid && existing().status != 'Closed')
      );
      allow delete: if isAdmin();
    }

    // 2.2 Change Control
    match /changeControls/{ccId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Add more strict validation later
      allow update: if isSignedIn() && (isAdmin() || isQA() || isManager());
      allow delete: if isAdmin();
    }

    // 2.3 CAPA
    match /capas/{capaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || isQA() || existing().ownerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 2.6 Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 3.1 Risks
    match /risks/{riskId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isQA() || isManager();
    }
  }
}
